system MultiInst;
  var c1 : channel(32);
  var c2 : channel(32);

  process Producer = "producer.csp"
    port out R : channel(32);

  process Consumer = "consumer.csp"
    port in L : channel(32);

begin
  var p1 : Producer(R => c1);
  var p2 : Producer(R => c2);
  var q1 : Consumer(L => c1);
  var q2 : Consumer(L => c2);
end.
