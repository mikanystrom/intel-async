// Circular dependency: A sends c1 then recvs c2, B sends c2 then recvs c1.
// Both start by sending, but each needs the other to receive first.
// Deadlock: circular wait.
system DeadlockCycle;
  var c1 : channel(32);
  var c2 : channel(32);

  process ProcA = "deadlock_a.csp"
    port out R : channel(32)
    port in L : channel(32);

  process ProcB = "deadlock_b.csp"
    port out R : channel(32)
    port in L : channel(32);

begin
  var a : ProcA(R => c1, L => c2);
  var b : ProcB(R => c2, L => c1);
end.
