system MultiInstance;
  var c1 : channel(32);
  var c2 : channel(32);

  process Src = "producer.csp"
    port out R : channel(32);

  process Dst = "consumer.csp"
    port in L : channel(32);

begin
  var s1 : Src(R => c1);
  var s2 : Src(R => c2);
  var d1 : Dst(L => c1);
  var d2 : Dst(L => c2);
end.
