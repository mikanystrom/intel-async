system MultiProcess;
  var c1 : channel(32);
  var c2 : channel(32);

  process Src = "producer.csp"
    port out R : channel(32);

  process Fwd = "passthrough.csp"
    port in L : channel(32)
    port out R : channel(32);

  process Dst = "consumer.csp"
    port in L : channel(32);

begin
  var s : Src(R => c1);
  var f : Fwd(L => c1, R => c2);
  var d : Dst(L => c2);
end.
