system Bidir;
  var c1 : channel(32);
  var c2 : channel(32);

  process Producer = "producer.csp"
    port out R : channel(32);

  process Adder = "adder.csp"
    port in L : channel(32)
    port out R : channel(32);

  process Sink = "sink.csp"
    port in L : channel(32);

begin
  var p : Producer(R => c1);
  var a : Adder(L => c1, R => c2);
  var s : Sink(L => c2);
end.
