VAR
  tbl : TextAirportTbl.T;

PROCEDURE Init() =
  VAR a : T;
  BEGIN
    tbl := NEW(TextAirportTbl.Default).init(N * 3);
    FOR i := 0 TO N - 1 DO
      a := NEW(T, icao := C_ICAO[i], iata := C_IATA[i],
               name := C_NAME[i],
               loc := GeoCoord.LatLonDeg(C_LAT[i], C_LON[i]));
      EVAL tbl.put(C_ICAO[i], a);
      EVAL tbl.put(C_IATA[i], a);
    END;
    FOR i := 0 TO NExtra - 1 DO
      VAR v : T; BEGIN
        IF tbl.get(C_ICAO[C_EXTRA_IDX[i]], v) THEN
          EVAL tbl.put(C_EXTRA_CODE[i], v);
        END
      END
    END;
  END Init;

PROCEDURE ToUpper(t : TEXT) : TEXT =
  VAR result : TEXT := ""; c : CHAR;
  BEGIN
    FOR i := 0 TO Text.Length(t) - 1 DO
      c := Text.GetChar(t, i);
      IF c >= 'a' AND c <= 'z' THEN
        c := VAL(ORD(c) - ORD('a') + ORD('A'), CHAR);
      END;
      result := result & Text.FromChar(c);
    END;
    RETURN result
  END ToUpper;

PROCEDURE Lookup(code : TEXT) : T =
  VAR
    upper := ToUpper(code);
    result : T;
  BEGIN
    IF tbl.get(upper, result) THEN
      RETURN result
    END;
    RETURN NIL
  END Lookup;

PROCEDURE Count() : CARDINAL =
  BEGIN
    RETURN N
  END Count;

BEGIN
  Init();
END Airport.
